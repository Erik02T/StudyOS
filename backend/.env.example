# Runtime / environment
# Valid APP_ENV values: local, test, staging, production
APP_ENV=local
# Railway injects RAILWAY_ENVIRONMENT_NAME automatically. Keep APP_ENV explicit in deployed environments.

# App
APP_NAME=StudyOS API
APP_VERSION=0.1.0
PUBLIC_APP_URL=http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https:\/\/.*\.vercel\.app$
SECURITY_HEADERS_ENABLED=true

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/studyos

# Auth
SECRET_KEY=d002c9b-8f1e-4c3a-9c3b-2f0e5d6a7b8c
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200
ALGORITHM=HS256
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=300
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# Local-only convenience. Test environments can opt in explicitly if needed.
# ACTION_TOKEN_EXPOSE_IN_RESPONSE=true

# Email
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@studyos.dev
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
EMAIL_RESEND_API_KEY=
EMAIL_RESEND_BASE_URL=https://api.resend.com/emails
EMAIL_MAX_ATTEMPTS=5
EMAIL_WORKER_POLL_SECONDS=5

# Billing
# Local-only convenience. If unset, manual plan changes are enabled only when APP_ENV=local.
# BILLING_ALLOW_MANUAL_PLAN_CHANGE=true
BILLING_FREE_MAX_SUBJECTS=10
BILLING_FREE_TASKS_PER_MONTH=150
BILLING_FREE_REVIEWS_PER_MONTH=600
BILLING_FREE_SESSIONS_PER_MONTH=200
BILLING_PRO_MAX_SUBJECTS=999999
BILLING_PRO_TASKS_PER_MONTH=999999
BILLING_PRO_REVIEWS_PER_MONTH=999999
BILLING_PRO_SESSIONS_PER_MONTH=999999
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
# Local/test only. Keep unset in deployed environments.
# STRIPE_ALLOW_INSECURE_WEBHOOKS=true

# Observability
LOG_LEVEL=INFO
JSON_LOGS_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
